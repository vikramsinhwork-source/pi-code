# Raspberry Pi Agent — Vatva/Botad station (provisioned in backend)
# DEVICE_ID must be the UUID from admin (POST /api/devices), NOT a stream name like kiosk1
DEVICE_ID=b6ee0d2b-a66c-416f-b266-ad372f42ebae

STATION_CODE=ADI

API_URL=https://railwaymonitor.in
SOCKET_URL=https://railwaymonitor.in

# Must match DEVICE_TOKEN_SECRET in railway-monitor backend .env
DEVICE_TOKEN_SECRET=change-this-device-token-secret

STREAM_NAME=kiosk1
GO2RTC_URL=http://127.0.0.1:1984
KIOSK_DISPLAY=:0
AGENT_REPO_PATH=/home/pi/railwatch-agent
PM2_APP_NAME=railwatch-agent
