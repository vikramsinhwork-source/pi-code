# Raspberry Pi Agent Configuration

# Device UUID from admin — ONE per lobby Raspberry Pi (not per camera/kiosk).
# The Pi agent registers MediaMTX paths (camera1, camera2, …) under this id.
DEVICE_ID=00000000-0000-4000-8000-000000000001

# Station identifier (optional, stored in metadata)
STATION_CODE=VATVA

# Backend API base URL
API_URL=https://railwaymonitor.in

# Socket.IO server URL (defaults to API_URL)
SOCKET_URL=https://railwaymonitor.in

# Shared secret for POST /api/auth/device-token
DEVICE_TOKEN_SECRET=change-this-device-token-secret

# Agent version reported to backend
AGENT_VERSION=1.0.0

# PM2 process name used by restart-agent command (must match ecosystem.config.js)
PM2_APP_NAME=railwatch-agent

# Intervals (milliseconds)
HEARTBEAT_INTERVAL_MS=30000
STREAM_POLL_INTERVAL_MS=30000
STREAM_FRAME_INTERVAL_MS=2000
STREAM_FRAME_VNC_INTERVAL_MS=15000
RECONNECT_DELAY_MS=5000
TOKEN_REFRESH_MARGIN_MS=300000

# MediaMTX local API and WebRTC page base (for diagnostics)
MEDIAMTX_API_URL=http://127.0.0.1:9997
MEDIAMTX_WEBRTC_BASE_URL=http://127.0.0.1:8889

# LAN IP monitors use for direct WebRTC playback (192.168.x preferred over VPN 10.x).
# Set explicitly when the Pi has multiple interfaces, e.g. PI_PLAYBACK_IP=192.168.1.8
PI_PLAYBACK_IP=

# Comma-separated MediaMTX path names this Pi exposes
MEDIAMTX_PATHS=camera1,camera2,camera3,camera4,camera5

# WebRTC-only Pi: disable persistent ffmpeg JPEG decoders (avoids extra RTSP pulls).
JPEG_PIPELINE_ENABLED=false

# Kiosk screenshot via vncsnapshot (host:display), e.g. 10.71.35.210:0
KIOSK_VNC_TARGET=

# Display for desktop screenshot (scrot)
KIOSK_DISPLAY=:0

# Temporary screenshot directory (cleaned after upload)
SCREENSHOT_DIR=/tmp/railwatch-screenshots

# Git repo path for remote updates (directory containing agent/)
AGENT_REPO_PATH=/home/pi/railwatch-agent
